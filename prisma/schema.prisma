generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(225)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("update_at")

  ciudades Ciudad[]
  planes   Planes[]
  tokens   TokenRevocado[]

  @@map("usuario")
}

model Ciudad {
  id           Int      @id @default(autoincrement())
  idUsuario    Int      @map("id_usuario")
  nombre       String   @db.VarChar(100)
  estado       String?  @db.VarChar(100)
  codigoPais   String   @map("codigo_pais") @db.Char(2)
  codigoPostal String?  @map("codigo_postal") @db.Char(10)
  lat          Decimal? @db.Decimal(9, 6)
  lon          Decimal? @db.Decimal(9, 6)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("update_at")

  usuario Usuario  @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  planes  Planes[]

  @@map("ciudad")
}

model Planes {
  id            Int       @id @default(autoincrement())
  idUsuario     Int       @map("id_usuario")
  idCiudad      Int       @map("id_ciudad")
  fecha         DateTime? @db.Date
  actividad     String    @db.VarChar(100)
  notas         String?   @db.VarChar(100)
  completado    Boolean   @default(false)
  climaEsperado String?   @map("clima_esperado") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("update_at")

  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ciudad  Ciudad  @relation(fields: [idCiudad], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("planes")
}

model TokenRevocado {
  id        Int       @id @default(autoincrement())
  token     String    @db.Text
  idUsuario Int       @map("id_usuario")
  expiraEn  DateTime? @map("expira_en")
  createdAt DateTime  @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("token_revocado")
}